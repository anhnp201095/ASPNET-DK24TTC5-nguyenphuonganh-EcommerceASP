@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div style="padding:40px; text-align:center; border:1px solid #e4e7ed; border-radius:10px; background:#fff;">
                    <h2 style="color:#D10024; margin-bottom:15px;">Đặt hàng thành công</h2>
                    <p style="margin-bottom:20px;">Cảm ơn bạn đã mua hàng tại cửa hàng của chúng tôi.</p>

                    <a asp-controller="Home"
                       asp-action="Index"
                       class="primary-btn"
                       style="text-decoration:none;">
                        Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>