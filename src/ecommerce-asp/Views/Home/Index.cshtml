@model List<ecommerce_asp.Models.Laptop>
@using ecommerce_asp.Models
@inject AppDbContext _context

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    int? customerId = Context.Session.GetInt32("CustomerId");
}

<div class="section">
    <div class="container">
        <div class="row">

            <div class="col-md-3">
                <div class="aside">
                    <h3 class="aside-title">DANH MỤC</h3>
                    <div class="checkbox-filter">
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var category in ViewBag.Categories)
                            {
                                bool isSelected = ViewBag.SelectedCategoryId != null
                                && ViewBag.SelectedCategoryId == category.CategoryId;

                                <div class="input-checkbox">
                                    <label>
                                        <span></span>
                                        <a asp-controller="Home"
                                           asp-action="Index"
                                           asp-route-categoryId="@category.CategoryId"
                                           asp-route-brandId="@ViewBag.SelectedBrandId"
                                           asp-route-keyword="@ViewBag.Keyword"
                                           style="font-weight:@(isSelected ? "bold" : "normal"); color:@(isSelected ? "#D10024" : "inherit")">
                                            @category.Name
                                        </a>
                                    </label>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="aside">
                    <h3 class="aside-title">THƯƠNG HIỆU</h3>
                    <div class="checkbox-filter">
                        @if (ViewBag.Brands != null)
                        {
                            foreach (var brand in ViewBag.Brands)
                            {
                                bool isSelected = ViewBag.SelectedBrandId != null
                                && ViewBag.SelectedBrandId == brand.BrandId;

                                <div class="input-checkbox">
                                    <label>
                                        <span></span>
                                        <a asp-controller="Home"
                                           asp-action="Index"
                                           asp-route-categoryId="@ViewBag.SelectedCategoryId"
                                           asp-route-brandId="@brand.BrandId"
                                           asp-route-keyword="@ViewBag.Keyword"
                                           style="font-weight:@(isSelected ? "bold" : "normal"); color:@(isSelected ? "#D10024" : "inherit")">
                                            @brand.Name
                                        </a>
                                    </label>
                                </div>
                            }
                        }
                    </div>
                </div>

                @if (ViewBag.SelectedCategoryId != null || ViewBag.SelectedBrandId != null || !string.IsNullOrEmpty(ViewBag.Keyword))
                {
                    <div class="aside">
                        <a asp-controller="Home"
                           asp-action="Index"
                           class="primary-btn"
                           style="display:block; width:100%; text-align:center; text-decoration:none;">
                            Bỏ lọc
                        </a>
                    </div>
                }
            </div>

            <div class="col-md-9">
                <div class="row">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            bool isInWishlist = false;

                            if (customerId != null)
                            {
                                isInWishlist = _context.Wishlists.Any(w =>
                                w.CustomerId == customerId.Value && w.LaptopId == item.LaptopId);
                            }

                            <div class="col-md-4 col-xs-6">
                                <div class="product">
                                    <div class="product-img" style="position:relative;">
                                        <a asp-controller="Product"
                                           asp-action="Detail"
                                           asp-route-id="@item.LaptopId">
                                            <img src="~/img/@item.ImageUrl"
                                                 alt="@item.Name"
                                                 style="width:100%; height:250px; object-fit:cover;" />
                                        </a>

                                        <a asp-controller="Wishlist"
                                           asp-action="Toggle"
                                           asp-route-id="@item.LaptopId"
                                           style="position:absolute; top:10px; right:10px; width:38px; height:38px; border-radius:50%; background:#fff; display:flex; align-items:center; justify-content:center; text-decoration:none; box-shadow:0 2px 8px rgba(0,0,0,0.15);">
                                            <i class="fa @(isInWishlist ? "fa-heart" : "fa-heart-o")" style="color:#D10024;"></i>
                                        </a>
                                    </div>

                                    <div class="product-body">
                                        <p class="product-category">
                                            @(item.Brand != null ? item.Brand.Name : "Laptop")
                                        </p>

                                        <h3 class="product-name">
                                            <a asp-controller="Product"
                                               asp-action="Detail"
                                               asp-route-id="@item.LaptopId">
                                                @item.Name
                                            </a>
                                        </h3>

                                        <h4 class="product-price">
                                            @item.Price.ToString("N0") VNĐ
                                        </h4>
                                    </div>

                                    <div class="add-to-cart">
                                        <a asp-controller="Cart"
                                           asp-action="Add"
                                           asp-route-id="@item.LaptopId"
                                           class="add-to-cart-btn"
                                           style="display:flex; align-items:center; justify-content:center; gap:8px;">
                                            <i class="fa fa-shopping-cart"></i>
                                            <span>Thêm vào giỏ hàng</span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-md-12">
                            <h3>Chưa có sản phẩm nào</h3>
                        </div>
                    }
                </div>

                <div class="store-filter clearfix">
                    <ul class="store-pagination">
                        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
                        {
                            @if (ViewBag.CurrentPage > 1)
                            {
                                <li>
                                    <a asp-controller="Home"
                                       asp-action="Index"
                                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-categoryId="@ViewBag.SelectedCategoryId"
                                       asp-route-brandId="@ViewBag.SelectedBrandId">
                                        <i class="fa fa-angle-left"></i>
                                    </a>
                                </li>
                            }

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="@(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a asp-controller="Home"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-categoryId="@ViewBag.SelectedCategoryId"
                                       asp-route-brandId="@ViewBag.SelectedBrandId">
                                        @i
                                    </a>
                                </li>
                            }

                            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                            {
                                <li>
                                    <a asp-controller="Home"
                                       asp-action="Index"
                                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                                       asp-route-keyword="@ViewBag.Keyword"
                                       asp-route-categoryId="@ViewBag.SelectedCategoryId"
                                       asp-route-brandId="@ViewBag.SelectedBrandId">
                                        <i class="fa fa-angle-right"></i>
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>

            </div>
        </div>
    </div>
</div>