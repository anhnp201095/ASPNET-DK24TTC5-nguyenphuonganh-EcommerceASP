<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Trang quản trị</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/font-awesome.min.css" />
</head>
<body style="background:#f5f5f5;">

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2" style="background:#2B2D42; min-height:100vh; padding:0;">
                <div style="padding:20px; color:white; font-size:22px; font-weight:700; text-align:center; border-bottom:1px solid rgba(255,255,255,0.1);">
                    ADMIN
                </div>

                <ul style="list-style:none; margin:0; padding:0;">
                    <li>
                        <a asp-controller="Admin"
                           asp-action="Index"
                           style="display:block; padding:15px 20px; color:white; text-decoration:none; border-bottom:1px solid rgba(255,255,255,0.05);">
                            <i class="fa fa-dashboard"></i> Tổng quan
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin"
                           asp-action="Products"
                           style="display:block; padding:15px 20px; color:white; text-decoration:none; border-bottom:1px solid rgba(255,255,255,0.05);">
                            <i class="fa fa-laptop"></i> Quản lý sản phẩm
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin"
                           asp-action="Orders"
                           style="display:block; padding:15px 20px; color:white; text-decoration:none; border-bottom:1px solid rgba(255,255,255,0.05);">
                            <i class="fa fa-shopping-bag"></i> Quản lý đơn hàng
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin"
                           asp-action="Customers"
                           style="display:block; padding:15px 20px; color:white; text-decoration:none; border-bottom:1px solid rgba(255,255,255,0.05);">
                            <i class="fa fa-users"></i> Quản lý khách hàng
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Home"
                           asp-action="Index"
                           style="display:block; padding:15px 20px; color:white; text-decoration:none;">
                            <i class="fa fa-home"></i> Về trang chủ
                        </a>
                    </li>
                </ul>
            </div>

            <div class="col-md-10" style="padding:0;">
                <div style="background:white; padding:20px; border-bottom:1px solid #ddd; display:flex; justify-content:space-between; align-items:center;">
                    <h3 style="margin:0;">Trang quản trị hệ thống</h3>
                    <a asp-controller="Account"
                       asp-action="Logout"
                       class="btn btn-danger">
                        Đăng xuất
                    </a>
                </div>

                <div style="padding:25px;">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/bootstrap.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>